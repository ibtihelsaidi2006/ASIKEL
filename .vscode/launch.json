{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch ASIKEL (about.html)",
      "type": "pwa-chrome",
      "request": "launch",
      "file": "${workspaceFolder}/about.html",
      "webRoot": "${workspaceFolder}"
    },
    {
      "name": "Attach to Chrome",
      "type": "pwa-chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}"
    }
  ]
}